{
  "name": "pdfplum",
  "version": "0.17.2",
  "description": "Generate PDF documents from templates stored in Firebase Storage",
  "author": "PDFPlum (hi@pdfplum.com)",
  "repository": "https://github.com/pdfplum/pdfplum",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "format": "eslint --fix --ext .js,.ts .",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf ./build/",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "test": "jest"
  },
  "engines": {
    "node": "16"
  },
  "main": "build/src/index.js",
  "dependencies": {
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "firebase": "^10.9.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.8.1",
    "firebase-functions-test": "^3.1.1",
    "get-port-please": "^3.1.2",
    "googleapis": "^134.0.0",
    "handlebars": "^4.7.8",
    "handlebars-helpers": "^0.10.0",
    "jest": "^29.7.0",
    "jszip": "^3.10.1",
    "module-alias": "^2.2.3",
    "path": "^0.12.7",
    "puppeteer": "^18",
    "serve-static": "^1.15.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.3"
  },
  "_moduleAliases": {
    "lib": "build/lib",
    "src": "build/src"
  },
  "private": true
}
